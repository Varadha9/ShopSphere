<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="BookSphere Test Suite" verbose="1">

    <test name="Smoke Tests">
        <groups>
            <run><include name="smoke"/></run>
        </groups>
        <classes>
            <class name="com.booksphere.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <groups>
            <run><include name="regression"/></run>
        </groups>
        <classes>
            <class name="com.booksphere.tests.CatalogTest"/>
            <class name="com.booksphere.tests.CartTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <groups>
            <run><include name="api"/></run>
        </groups>
        <classes>
            <class name="com.booksphere.tests.ApiTest"/>
        </classes>
    </test>

    <test name="BDD Tests">
        <classes>
            <class name="com.booksphere.runner.CucumberRunner"/>
        </classes>
    </test>

</suite>
