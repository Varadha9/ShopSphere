    {
      "name": "💖 Wishlist (Private)",
      "item": [
        {
          "name": "GET My Wishlist",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{user_jwt}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/wishlists?select=*&user_id=eq.{{user_id}}"
          }
        },
        {
          "name": "POST Add to Wishlist (book p3 = Dune)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{user_jwt}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Prefer",        "value": "return=representation,resolution=merge-duplicates" }
            ],
            "url": "{{supabase_url}}/rest/v1/wishlists",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"book_id\": \"p3\"\n}"
            }
          }
        },
        {
          "name": "POST Add to Wishlist (book p6 = Atomic Habits)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{user_jwt}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Prefer",        "value": "return=representation,resolution=merge-duplicates" }
            ],
            "url": "{{supabase_url}}/rest/v1/wishlists",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"book_id\": \"p6\"\n}"
