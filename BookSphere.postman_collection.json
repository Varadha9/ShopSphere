{
  "info": {
    "name": "BookSphere — Supabase API",
    "description": "Complete REST API collection for BookSphere.\n\nSetup:\n1. Set {{user_jwt}} = access_token from Login response\n2. Set {{user_id}} = user id from Login response (user.id)\n3. All other variables are pre-filled.\n\nFlow: Run Login first → copy access_token → paste into user_jwt variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "supabase_url", "value": "https://vckpdkzsfeeibldxippd.supabase.co" },
    { "key": "anon_key",     "value": "sb_publishable_5pi0OY09IbihgQliazw5ug_G5ha_SxJ" },
    { "key": "user_jwt",     "value": "PASTE_ACCESS_TOKEN_HERE_AFTER_LOGIN" },
    { "key": "user_id",      "value": "PASTE_USER_UUID_HERE_AFTER_LOGIN" },
    { "key": "order_id",     "value": "ORD-TEST-001" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register (Email + Password)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey",       "value": "{{anon_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{supabase_url}}/auth/v1/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@1234\",\n  \"data\": {\n    \"name\": \"Test User\",\n    \"isPremium\": false\n  }\n}"
            }
          }
        },
        {
          "name": "Login (Email + Password) ← run this first",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('user_jwt', json.access_token);",
                  "}",
                  "if (json.user && json.user.id) {",
                  "  pm.collectionVariables.set('user_id', json.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey",       "value": "{{anon_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{supabase_url}}/auth/v1/token?grant_type=password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{user_jwt}}" }
            ],
            "url": "{{supabase_url}}/auth/v1/logout"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{user_jwt}}" }
            ],
            "url": "{{supabase_url}}/auth/v1/user"
          }
        },
        {
          "name": "Forgot Password (Send Reset Email)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey",       "value": "{{anon_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{supabase_url}}/auth/v1/recover",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "📚 Books (Public)",
      "item": [
        {
          "name": "GET All Books",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/books?select=*"
          }
        },
        {
          "name": "GET Books by Category = Fiction",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/books?select=*&category=eq.Fiction"
          }
        },
        {
          "name": "GET Books sorted by Price (asc)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/books?select=*&order=price.asc"
          }
        },
        {
          "name": "GET Books sorted by Rating (desc)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/books?select=*&order=rating.desc"
          }
        },
        {
          "name": "GET Single Book by ID (p1)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/books?select=*&id=eq.p1"
          }
        }
      ]
    },

    {
      "name": "🏷️ Coupons (Public)",
      "item": [
